# ============================================================
# Sao chép file này thành .env rồi điền giá trị thực
# cp .env.example .env
# ============================================================

# MySQL root password (chỉ dùng nội bộ bởi Docker MySQL container)
DB_ROOT_PASSWORD=root_secret_changeme

# App database — backend kết nối bằng thông tin này
DB_NAME=hoc_tieng_trung
DB_USER=appuser
DB_PASSWORD=app_secret_changeme

# JWT Secrets
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_secret
JWT_REFRESH_SECRET=change_this_to_another_random_secret
